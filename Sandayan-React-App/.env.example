# Frontend environment variables for Vite
# Copy values into .env for local development.

# OpenWeather API key used by src/services/weatherApi.js
VITE_WEATHER_API_KEY=your_weather_api_key_here

# Optional: Laravel API base URL (defaults to http://127.0.0.1:8000)
VITE_API_BASE_URL=http://127.0.0.1:8000
